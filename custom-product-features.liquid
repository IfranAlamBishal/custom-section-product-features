{% style %}
.feature-section-{{ section.id }} {
  background-color: {{ section.settings.bg_color }};
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

/* SECTION HEADER STYLES */
.feature-section-header-{{ section.id }} {
  text-align: {{ section.settings.section_text_alignment }};
  margin-bottom: {{ section.settings.section_heading_margin }}px;
  padding: 0 20px;
  max-width: 1440px;
  margin-inline: auto;
}

.feature-section-heading-{{ section.id }} {
  font-size: {{ section.settings.section_heading_size }}px;
  font-weight: {{ section.settings.section_heading_weight }};
  color: {{ section.settings.section_heading_color }};
  margin: 0 0 15px 0;
  line-height: 1.2;
}

.feature-section-subheading-{{ section.id }} {
  font-size: {{ section.settings.section_subheading_size }}px;
  font-weight: {{ section.settings.section_subheading_weight }};
  color: {{ section.settings.section_subheading_color }};
  max-width: 800px;
  margin: 0 auto;
  line-height: 1.5;
}

/* MAIN GRID STYLES */
.feature-inner-{{ section.id }} {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 20px;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 40px;
  align-items: center;
}

.feature-column-{{ section.id }} {
  display: flex;
  flex-direction: column;
  gap: 36px; /* Global gap, block specific padding added inline */
}

.feature-item-{{ section.id }} {
  display: flex;
  align-items: var(--align-items-desktop, flex-start);
  text-align: var(--text-align-desktop, left);
  gap: 16px;
  flex-direction: var(--flex-direction-desktop, row); /* Controls icon position */
}

.feature-icon-{{ section.id }} {
  flex: 0 0 {{ section.settings.icon_size }}px;
  width: {{ section.settings.icon_size }}px;
  height: {{ section.settings.icon_size }}px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature-icon-{{ section.id }} img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}

.feature-content-{{ section.id }} {
  flex: 1; /* Ensures text block takes remaining space */
}

.feature-content-{{ section.id }} h4 {
  font-size: {{ section.settings.heading_size }}px;
  font-weight: {{ section.settings.heading_weight }};
  color: {{ section.settings.heading_color }};
  margin-top: 0;
  margin-bottom: 8px !important;
  text-transform: uppercase;
  letter-spacing: 1px;
  line-height: 1.3;
}

.feature-content-{{ section.id }} p {
  font-size: {{ section.settings.text_size }}px;
  color: {{ section.settings.text_color }};
  margin: 0;
  line-height: 1.6;
}

.feature-image-{{ section.id }} img {
  max-width: {{ section.settings.image_width }}px;
  width: 100%;
  height: auto;
  display: block;
  margin-inline: auto;
  {% if section.settings.enable_floating_image %}
  animation: floatImage-{{ section.id }} 4s ease-in-out infinite;
  {% endif %}
}

{% if section.settings.enable_floating_image %}
@keyframes floatImage-{{ section.id }} {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-20px); }
  100% { transform: translateY(0px); }
}
{% endif %}

@media (max-width: 990px) {
  .feature-section-heading-{{ section.id }} {
    font-size: {{ section.settings.section_heading_size | times: 0.8 | round }}px;
  }
  
  .feature-section-subheading-{{ section.id }} {
    font-size: {{ section.settings.section_subheading_size | times: 0.9 | round }}px;
  }

  .feature-inner-{{ section.id }} {
    grid-template-columns: 1fr;
  }

  .feature-item-{{ section.id }} {
    flex-direction: var(--flex-direction-mobile, column);
    align-items: var(--align-items-mobile, center);
    text-align: var(--text-align-mobile, center);
  }
}
{% endstyle %}

<section class="feature-section-{{ section.id }}">
  
  <!-- OPTIONAL SECTION HEADING -->
  {%- if section.settings.section_heading != blank or section.settings.section_subheading != blank -%}
    <div class="feature-section-header-{{ section.id }}">
      {%- if section.settings.section_heading != blank -%}
        <h2 class="feature-section-heading-{{ section.id }}">{{ section.settings.section_heading }}</h2>
      {%- endif -%}
      {%- if section.settings.section_subheading != blank -%}
        <p class="feature-section-subheading-{{ section.id }}">{{ section.settings.section_subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="feature-inner-{{ section.id }}">

    <!-- LEFT FEATURES -->
    <div class="feature-column-{{ section.id }}">
      {% for block in section.blocks %}
        {% if block.settings.position == 'left' %}
          
          {%- liquid
            assign desktop_align_items = 'flex-start'
            if block.settings.text_alignment == 'center' or block.settings.icon_position == 'top'
              assign desktop_align_items = 'center'
            elsif block.settings.text_alignment == 'right'
              assign desktop_align_items = 'flex-end'
            endif
            
            assign mobile_align_items = 'flex-start'
            if block.settings.mobile_text_alignment == 'center' or block.settings.icon_position == 'top'
              assign mobile_align_items = 'center'
            elsif block.settings.mobile_text_alignment == 'right'
              assign mobile_align_items = 'flex-end'
            endif

            assign flex_dir_desk = 'row'
            if block.settings.icon_position == 'right'
              assign flex_dir_desk = 'row-reverse'
            elsif block.settings.icon_position == 'top'
              assign flex_dir_desk = 'column'
            endif

            assign flex_dir_mob = 'column'
            if block.settings.icon_position == 'left'
              assign flex_dir_mob = 'row'
            elsif block.settings.icon_position == 'right'
              assign flex_dir_mob = 'row-reverse'
            endif
          -%}

          <div class="feature-item-{{ section.id }}" style="--text-align-desktop: {{ block.settings.text_alignment }}; --align-items-desktop: {{ desktop_align_items }}; --flex-direction-desktop: {{ flex_dir_desk }}; --text-align-mobile: {{ block.settings.mobile_text_alignment }}; --align-items-mobile: {{ mobile_align_items }}; --flex-direction-mobile: {{ flex_dir_mob }}; padding-top: {{ block.settings.block_padding_top }}px; padding-bottom: {{ block.settings.block_padding_bottom }}px;" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              <div class="feature-icon-{{ section.id }}">
                <img src="{{ block.settings.icon | image_url: width: 600 }}" alt="" loading="lazy">
              </div>
            {% endif %}
            
            <div class="feature-content-{{ section.id }}">

              {% if block.settings.subheading != blank %}
                <div style="font-size: {{ block.settings.subheading_size }}px; font-weight: {{ block.settings.subheading_weight }}; color: {{ block.settings.subheading_color }}; {% if block.settings.subheading_bg != 'rgba(0,0,0,0)' and block.settings.subheading_bg != blank %}background-color: {{ block.settings.subheading_bg }}; display: inline-block; padding: 4px 10px; border-radius: 20px;{% endif %} margin-bottom: 8px;">
                  {{ block.settings.subheading }}
                </div>
              {% endif %}

              {% if block.settings.title != blank %}
                <h4 style="{% if block.settings.title_bg != 'rgba(0,0,0,0)' and block.settings.title_bg != blank %}background-color: {{ block.settings.title_bg }}; display: inline-block; padding: 4px 10px; border-radius: 4px;{% endif %}">
                  {{ block.settings.title }}
                </h4>
              {% endif %}

              <p>{{ block.settings.text }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <!-- CENTER IMAGE -->
    <div class="feature-image-{{ section.id }}">
      {% if section.settings.center_image != blank %}
        <img src="{{ section.settings.center_image | image_url: width: 1000 }}" alt="">
      {% endif %}
    </div>

    <!-- RIGHT FEATURES -->
    <div class="feature-column-{{ section.id }}">
      {% for block in section.blocks %}
        {% if block.settings.position == 'right' %}
          
          {%- liquid
            assign desktop_align_items = 'flex-start'
            if block.settings.text_alignment == 'center' or block.settings.icon_position == 'top'
              assign desktop_align_items = 'center'
            elsif block.settings.text_alignment == 'right'
              assign desktop_align_items = 'flex-end'
            endif
            
            assign mobile_align_items = 'flex-start'
            if block.settings.mobile_text_alignment == 'center' or block.settings.icon_position == 'top'
              assign mobile_align_items = 'center'
            elsif block.settings.mobile_text_alignment == 'right'
              assign mobile_align_items = 'flex-end'
            endif

            assign flex_dir_desk = 'row'
            if block.settings.icon_position == 'right'
              assign flex_dir_desk = 'row-reverse'
            elsif block.settings.icon_position == 'top'
              assign flex_dir_desk = 'column'
            endif

            assign flex_dir_mob = 'column'
            if block.settings.icon_position == 'left'
              assign flex_dir_mob = 'row'
            elsif block.settings.icon_position == 'right'
              assign flex_dir_mob = 'row-reverse'
            endif
          -%}

          <div class="feature-item-{{ section.id }}" style="--text-align-desktop: {{ block.settings.text_alignment }}; --align-items-desktop: {{ desktop_align_items }}; --flex-direction-desktop: {{ flex_dir_desk }}; --text-align-mobile: {{ block.settings.mobile_text_alignment }}; --align-items-mobile: {{ mobile_align_items }}; --flex-direction-mobile: {{ flex_dir_mob }}; padding-top: {{ block.settings.block_padding_top }}px; padding-bottom: {{ block.settings.block_padding_bottom }}px;" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              <div class="feature-icon-{{ section.id }}">
                <img src="{{ block.settings.icon | image_url: width: 600 }}" alt="" loading="lazy">
              </div>
            {% endif %}
            
            <div class="feature-content-{{ section.id }}">

              {% if block.settings.subheading != blank %}
                <div style="font-size: {{ block.settings.subheading_size }}px; font-weight: {{ block.settings.subheading_weight }}; color: {{ block.settings.subheading_color }}; {% if block.settings.subheading_bg != 'rgba(0,0,0,0)' and block.settings.subheading_bg != blank %}background-color: {{ block.settings.subheading_bg }}; display: inline-block; padding: 4px 10px; border-radius: 20px;{% endif %} margin-bottom: 8px;">
                  {{ block.settings.subheading }}
                </div>
              {% endif %}

              {% if block.settings.title != blank %}
                <h4 style="{% if block.settings.title_bg != 'rgba(0,0,0,0)' and block.settings.title_bg != blank %}background-color: {{ block.settings.title_bg }}; display: inline-block; padding: 4px 10px; border-radius: 4px;{% endif %}">
                  {{ block.settings.title }}
                </h4>
              {% endif %}

              <p>{{ block.settings.text }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
