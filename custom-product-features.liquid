      "label": "Heading Font Size",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 40
    },
    {
      "type": "select",
      "id": "section_heading_weight",
      "label": "Heading Font Weight",
      "options":[
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" },
        { "value": "900", "label": "Extra Bold" }
      ],
      "default": "700"
    },
    {
      "type": "color",
