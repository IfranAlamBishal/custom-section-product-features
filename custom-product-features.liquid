        { "type": "feature", "settings": {"position": "left"} },
        { "type": "feature", "settings": {"position": "left"} },
        { "type": "feature", "settings": {"position": "right"} },
        { "type": "feature", "settings": {"position": "right"} },
        { "type": "feature", "settings": {"position": "right"} }
      ]
    }
